<?xml version="1.0" ?>
<!-- SAFA-DCM: topology-aware placement (DCM-style, delay-minimising).
     Operators are assigned to transit nodes — the "near" tier — as
     SAFA's DCM algorithm would select the lowest-delay available nodes.
     Operator links pay E2Trans_link cost ($0.08/GB, 2ms delay);
     only the final hop to the sink pays E2C_high ($0.20/GB, 8.56ms). -->
<devices>
    <!-- Sources on edge Pi3Bs -->
    <device>
        <name>pi3Bs</name>
        <index-range>0</index-range>
        <tasks>
            <task>
                <name>so1</name>
                <category>so1</category>
                <type>ecsnetpp.stask.StreamingSource</type>
                <processingdelay><measuredtime>50000000</measuredtime></processingdelay>
                <msgsize>6880</msgsize>
                <sourceevdistribution>
                    <name>FixedSourceEventRateDistribution</name>
                    <type>ecsnetpp.model.source.eventrate.FixedSourceEventRateDistribution</type>
                </sourceevdistribution>
            </task>
        </tasks>
    </device>
    <device>
        <name>pi3Bs</name>
        <index-range>1</index-range>
        <tasks>
            <task>
                <name>so2</name>
                <category>so2</category>
                <type>ecsnetpp.stask.StreamingSource</type>
                <processingdelay><measuredtime>50000000</measuredtime></processingdelay>
                <msgsize>6880</msgsize>
                <sourceevdistribution>
                    <name>FixedSourceEventRateDistribution</name>
                    <type>ecsnetpp.model.source.eventrate.FixedSourceEventRateDistribution</type>
                </sourceevdistribution>
            </task>
        </tasks>
    </device>

    <!-- Operators on TRANSIT nodes (near, cheap — topology-aware DCM choice) -->
    <device>
        <name>transitNodes</name>
        <index-range>0</index-range>
        <tasks>
            <task>
                <name>op1</name>
                <category>op1</category>
                <type>ecsnetpp.stask.StreamingOperator</type>
                <processingdelay><measuredtime>748722</measuredtime></processingdelay>
                <selectivity>1</selectivity>
                <productivity>1</productivity>
            </task>
        </tasks>
    </device>
    <device>
        <name>transitNodes</name>
        <index-range>1</index-range>
        <tasks>
            <task>
                <name>op2</name>
                <category>op2</category>
                <type>ecsnetpp.stask.StreamingOperator</type>
                <processingdelay><measuredtime>748722</measuredtime></processingdelay>
                <selectivity>1</selectivity>
                <productivity>1</productivity>
            </task>
        </tasks>
    </device>

    <!-- Sink on cloud node (destination, always at cloud tier) -->
    <device>
        <name>cloudNodes</name>
        <index-range>0</index-range>
        <tasks>
            <task>
                <name>si</name>
                <category>si</category>
                <type>ecsnetpp.stask.StreamingSink</type>
                <processingdelay><measuredtime>195424</measuredtime></processingdelay>
            </task>
        </tasks>
    </device>
</devices>
